# ── Base de datos ─────────────────────────────────────────────────
# PRODUCCIÓN (Supabase): pega la "Connection string" (URI) de
# Supabase → Project Settings → Database → Connection string → URI.
# Usa el puerto 5432 (session pooler / direct) para migraciones.
#   DATABASE_URL=postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres
DATABASE_URL=
DB_SSLMODE=require
# DESARROLLO local (si no usas DATABASE_URL):
DB_NAME=alamex_omnichannel
DB_USER=postgres
DB_PASSWORD=
DB_HOST=localhost
DB_PORT=5432

# ── Django ────────────────────────────────────────────────────────
SECRET_KEY=
DEBUG=False
# Dominio(s) del backend desplegado (sin protocolo), separados por coma:
ALLOWED_HOSTS=tu-backend.onrender.com
# Origen(es) del frontend (CON protocolo) — el sitio de Netlify:
CORS_ALLOWED_ORIGINS=https://tu-sitio.netlify.app
# Por defecto = CORS_ALLOWED_ORIGINS; inclúyelo si difiere (admin tras HTTPS):
CSRF_TRUSTED_ORIGINS=https://tu-sitio.netlify.app
SECURE_SSL_REDIRECT=True

# ── Email (alertas de escalación SLA) ─────────────────────────────
# Vacío = consola. Para envíos reales, configura SMTP:
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=alertas@tu-dominio.com

# ── Celery (opcional — escaneo SLA en segundo plano) ──────────────
# Supabase no incluye Redis. Si no defines un broker, usa el cron de
# tu plataforma para correr:  python manage.py check_sla
CELERY_BROKER_URL=

# ── WhatsApp Cloud API ────────────────────────────────────────────
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_APP_SECRET=
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_META_APP_ID=

# ── Messenger ─────────────────────────────────────────────────────
MESSENGER_PAGE_ID=
MESSENGER_PAGE_ACCESS_TOKEN=
MESSENGER_APP_SECRET=
MESSENGER_VERIFY_TOKEN=
MESSENGER_META_APP_ID=

# ── Instagram ─────────────────────────────────────────────────────
INSTAGRAM_ACCOUNT_ID=
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_APP_SECRET=
INSTAGRAM_VERIFY_TOKEN=
INSTAGRAM_META_APP_ID=

# ── IA ────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ── Odoo ─────────────────────────────────────────────────────────
ODOO_URL=
ODOO_DB=
ODOO_USER=
ODOO_PASSWORD=
